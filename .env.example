PORT=8080
APP_TITLE=UniFi Blocklists
DATA_FILE=/app/data/blocklists.json
SETTINGS_FILE=/app/data/settings.json
APP_AUTH_USERNAME=admin
APP_AUTH_PASSWORD=change-this-password
APP_AUTH_PASSWORD_SEED=change-this-seed

# Accepte les certificats TLS auto-signes du controleur UniFi local.
ALLOW_INSECURE_TLS=true
REQUEST_TIMEOUT_MS=15000

# API locale UniFi Network. Exemple courant:
# https://ucg-fiber.local/proxy/network/integration/v1
UNIFI_NETWORK_BASE_URL=https://YOUR_UCG_FIBER/proxy/network/integration/v1
UNIFI_NETWORK_API_KEY=replace-with-your-local-unifi-api-key
UNIFI_SITE_ID=replace-with-your-site-id

# API cloud officielle Site Manager. Lecture seulement.
UNIFI_SITE_MANAGER_BASE_URL=https://api.ui.com/v1
UNIFI_SITE_MANAGER_API_KEY=

# Adaptateur blocklists.
# Les templates supportent:
# - {siteId}: UUID du site expose par l'API integration/v1
# - {siteRef}: reference legacy du site (souvent "default")
# - {networkRootUrl}: base derivee de UNIFI_NETWORK_BASE_URL sans /integration/v1
#
# Profil par defaut valide sur ce projet:
# https://<gateway>/proxy/network/api/s/{siteRef}/rest/firewallgroup
UNIFI_BLOCKLISTS_LIST_PATH={networkRootUrl}/api/s/{siteRef}/rest/firewallgroup
UNIFI_BLOCKLISTS_CREATE_PATH={networkRootUrl}/api/s/{siteRef}/rest/firewallgroup
UNIFI_BLOCKLISTS_UPDATE_PATH={networkRootUrl}/api/s/{siteRef}/rest/firewallgroup/{id}
UNIFI_BLOCKLISTS_DELETE_PATH={networkRootUrl}/api/s/{siteRef}/rest/firewallgroup/{id}
UNIFI_BLOCKLISTS_CREATE_METHOD=POST
UNIFI_BLOCKLISTS_UPDATE_METHOD=PUT
UNIFI_BLOCKLISTS_DELETE_METHOD=DELETE
UNIFI_BLOCKLISTS_ID_FIELD=_id
UNIFI_BLOCKLISTS_NAME_FIELD=name
UNIFI_BLOCKLISTS_DESCRIPTION_FIELD=
UNIFI_BLOCKLISTS_CIDRS_FIELD=group_members
# Taille maximale d'un groupe UniFi avant troncature ou division.
# Profils proposes dans l'interface: 2000 (USG), 4000 (Typical), 8000 (UDM Pro / UXG).
UNIFI_BLOCKLISTS_MAX_ENTRIES=4000
UNIFI_BLOCKLISTS_ENABLED_FIELD=
UNIFI_BLOCKLISTS_TAGS_FIELD=
UNIFI_MANAGED_TAG=managed-by-unifi-bl
UNIFI_BLOCKLISTS_EXTRA_PAYLOAD={"group_type":"address-group"}
