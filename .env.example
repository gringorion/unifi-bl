PORT=8080
APP_TITLE=UniFi Blocklists
DATA_FILE=/app/data/blocklists.json
SETTINGS_FILE=/app/data/settings.json
APP_AUTH_USERNAME=admin
# Format recommande:
# APP_AUTH_PASSWORD=sha256:<sha256(APP_AUTH_PASSWORD_SEED + ":" + mot_de_passe)>
# Exemple de generation:
# node -e 'const crypto=require("crypto");const seed="change-this-seed";const password="change-this-password";console.log("sha256:"+crypto.createHash("sha256").update(`${seed}:${password}`).digest("hex"))'
APP_AUTH_PASSWORD=change-this-password
APP_AUTH_PASSWORD_SEED=change-this-seed

# Accepte les certificats TLS auto-signes du controleur UniFi local.
ALLOW_INSECURE_TLS=true
REQUEST_TIMEOUT_MS=15000

# API locale UniFi Network. Exemple courant:
# https://ucg-fiber.local/proxy/network/integration/v1
UNIFI_NETWORK_BASE_URL=https://YOUR_UCG_FIBER/proxy/network/integration/v1
UNIFI_NETWORK_API_KEY=replace-with-your-local-unifi-api-key
UNIFI_SITE_ID=replace-with-your-site-id

# API cloud officielle Site Manager. Lecture seulement.
UNIFI_SITE_MANAGER_BASE_URL=https://api.ui.com/v1
UNIFI_SITE_MANAGER_API_KEY=

# Adaptateur blocklists.
# Les templates supportent:
# - {siteId}: UUID du site expose par l'API integration/v1
# - {siteRef}: reference legacy du site (souvent "default")
# - {networkRootUrl}: base derivee de UNIFI_NETWORK_BASE_URL sans /integration/v1
#
# Profil par defaut valide sur ce projet:
# https://<gateway>/proxy/network/api/s/{siteRef}/rest/firewallgroup
UNIFI_BLOCKLISTS_LIST_PATH={networkRootUrl}/api/s/{siteRef}/rest/firewallgroup
UNIFI_BLOCKLISTS_CREATE_PATH={networkRootUrl}/api/s/{siteRef}/rest/firewallgroup
UNIFI_BLOCKLISTS_UPDATE_PATH={networkRootUrl}/api/s/{siteRef}/rest/firewallgroup/{id}
UNIFI_BLOCKLISTS_DELETE_PATH={networkRootUrl}/api/s/{siteRef}/rest/firewallgroup/{id}
UNIFI_BLOCKLISTS_CREATE_METHOD=POST
UNIFI_BLOCKLISTS_UPDATE_METHOD=PUT
UNIFI_BLOCKLISTS_DELETE_METHOD=DELETE
UNIFI_BLOCKLISTS_ID_FIELD=_id
UNIFI_BLOCKLISTS_NAME_FIELD=name
UNIFI_BLOCKLISTS_DESCRIPTION_FIELD=
UNIFI_BLOCKLISTS_CIDRS_FIELD=group_members
# Taille maximale d'un groupe UniFi avant troncature ou division.
# Profils proposes dans l'interface: 2000 (USG), 4000 (Typical), 8000 (UDM Pro / UXG).
UNIFI_BLOCKLISTS_MAX_ENTRIES=4000
UNIFI_BLOCKLISTS_ENABLED_FIELD=
UNIFI_BLOCKLISTS_TAGS_FIELD=
UNIFI_MANAGED_TAG=managed-by-unifi-bl
UNIFI_BLOCKLISTS_EXTRA_PAYLOAD={"group_type":"address-group"}

# Policies firewall gerees automatiquement par unifi-bl.
# L'application cible d'abord les policies zone-based modernes exposees par
# /v2/api/site/{siteRef}/firewall-policies. Une policy entrante et une policy
# sortante sont creees pour chaque groupe UniFi retenu et pour chaque zone non-gateway.
UNIFI_FIREWALL_POLICIES_LIST_PATH={networkRootUrl}/v2/api/site/{siteRef}/firewall-policies
UNIFI_FIREWALL_POLICIES_CREATE_PATH={networkRootUrl}/v2/api/site/{siteRef}/firewall-policies
UNIFI_FIREWALL_POLICIES_UPDATE_PATH={networkRootUrl}/v2/api/site/{siteRef}/firewall-policies/{id}
UNIFI_FIREWALL_POLICIES_DELETE_PATH={networkRootUrl}/v2/api/site/{siteRef}/firewall-policies/{id}
UNIFI_FIREWALL_POLICIES_ZONE_MATRIX_PATH={networkRootUrl}/v2/api/site/{siteRef}/firewall/zone-matrix
UNIFI_FIREWALL_POLICIES_CREATE_METHOD=POST
UNIFI_FIREWALL_POLICIES_UPDATE_METHOD=PUT
UNIFI_FIREWALL_POLICIES_DELETE_METHOD=DELETE
UNIFI_FIREWALL_POLICIES_ID_FIELD=_id
UNIFI_FIREWALL_POLICIES_NAME_FIELD=name
UNIFI_FIREWALL_POLICIES_ENABLED_FIELD=enabled
UNIFI_FIREWALL_POLICY_NAME=unifi-bl - block enabled lists
UNIFI_FIREWALL_POLICIES_EXTRA_PAYLOAD={"connection_state_type":"ALL","connection_states":[],"create_allow_respond":false,"description":"","icmp_typename":"ANY","icmp_v6_typename":"ANY","ip_version":"IPV4","logging":false,"match_ip_sec":false,"match_opposite_protocol":false,"protocol":"all","schedule":{"mode":"ALWAYS"}}

# Compat legacy. Garde les anciens endpoints pour nettoyage/fallback si le
# controleur n'expose pas encore les policies modernes.
UNIFI_FIREWALL_RULES_LIST_PATH={networkRootUrl}/api/s/{siteRef}/rest/firewallrule
UNIFI_FIREWALL_RULES_CREATE_PATH={networkRootUrl}/api/s/{siteRef}/rest/firewallrule
UNIFI_FIREWALL_RULES_UPDATE_PATH={networkRootUrl}/api/s/{siteRef}/rest/firewallrule/{id}
UNIFI_FIREWALL_RULES_DELETE_PATH={networkRootUrl}/api/s/{siteRef}/rest/firewallrule/{id}
UNIFI_FIREWALL_RULES_CREATE_METHOD=POST
UNIFI_FIREWALL_RULES_UPDATE_METHOD=PUT
UNIFI_FIREWALL_RULES_DELETE_METHOD=DELETE
UNIFI_FIREWALL_RULES_ID_FIELD=_id
UNIFI_FIREWALL_RULES_NAME_FIELD=name
UNIFI_FIREWALL_RULES_ENABLED_FIELD=enabled
UNIFI_FIREWALL_RULES_SOURCE_GROUPS_FIELD=src_firewallgroup_ids
UNIFI_FIREWALL_RULES_DESTINATION_GROUPS_FIELD=dst_firewallgroup_ids
UNIFI_FIREWALL_RULE_NAME=unifi-bl - block enabled lists
# Profil partage par les regles legacy gerees; les rulesets WAN_IN et WAN_OUT et les rule_index
# sont ajoutes automatiquement par l'application en mode fallback seulement.
UNIFI_FIREWALL_RULES_EXTRA_PAYLOAD={"action":"drop","contiguous":false,"dst_networkconf_id":"","icmp_typename":"","icmpv6_typename":"","ipsec":"match-none","logging":false,"monthdays":"","monthdays_negate":false,"protocol":"all","protocol_match_excepted":false,"protocol_v6":"","setting_preference":"manual","src_mac_address":"","src_networkconf_id":"","startdate":"","starttime":"","state_established":false,"state_invalid":false,"state_new":false,"state_related":false,"stopdate":"","stoptime":"","utc":false,"weekdays":"","weekdays_negate":false}
