PORT=8080
APP_TITLE=UniFi Blocklists
APP_AUTH_USERNAME=
APP_AUTH_PASSWORD=
APP_AUTH_PASSWORD_SEED=

# Activez cette option si votre controleur utilise un certificat local.
ALLOW_INSECURE_TLS=true

# URL locale UniFi Network.
UNIFI_NETWORK_BASE_URL=https://YOUR_GATEWAY/proxy/network/integration/v1
UNIFI_NETWORK_API_KEY=replace-with-your-local-unifi-api-key
UNIFI_SITE_ID=default

# Taille maximale d'un groupe UniFi.
UNIFI_BLOCKLISTS_MAX_ENTRIES=4000
UNIFI_FIREWALL_POLICY_NAME=unifi-bl - block enabled lists
